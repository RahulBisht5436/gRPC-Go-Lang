# ---------------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------------

# Compiled binaries / object files
*.exe
*.exe~
*.dll
*.so
*.dylib
*.o
*.a

# Test binaries and coverage output
*.test
*.out
coverage.txt
coverage.html
profile.cov

# Go workspace file
go.work
go.work.sum

# Dependency directories (when vendoring is used)
vendor/

# Build output directories
/bin/
/build/
/dist/
/out/

# ---------------------------------------------------------------------------
# gRPC / Protobuf
# ---------------------------------------------------------------------------

# Generated protobuf / gRPC stubs (uncomment if you do NOT want to commit them)
# *.pb.go
# *_grpc.pb.go
# *_pb2.py
# *_pb2_grpc.py

# Protoc plugin downloads
/protoc/
/protoc-*/

# ---------------------------------------------------------------------------
